## Craft API configuration (Vite)
##
## Use separate share links (or document IDs) for Writing vs Projects so
## /writing never accidentally reads from the Projects document.
##
## Format for API base:
##   https://connect.craft.do/links/<YOUR_LINK_ID>/api/v1

# Optional shared base (used as fallback for both)
# VITE_CRAFT_API_BASE=

# Writing / Personal Blog
VITE_CRAFT_BLOG_API_BASE=
# Optional: bypass /documents and fetch directly
VITE_CRAFT_BLOG_DOCUMENT_ID=

# Projects
VITE_CRAFT_PROJECTS_API_BASE=
# Optional: bypass /documents and fetch directly
VITE_CRAFT_PROJECTS_DOCUMENT_ID=

